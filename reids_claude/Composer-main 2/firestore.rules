rules_version = '2';

// Firestore security rules for Composer
//
// Schema:
//   users/{uid}                       — user profile & settings
//   users/{uid}/saved/{id}            — personal saved itineraries/venues
//   users/{uid}/alerts/{id}           — upcoming-date notification rows
//   users/{uid}/dates/{dateId}        — completed dates with personal ratings
//   venues/{placeId}                  — venue-level metadata
//   venues/{placeId}/ratings/{rid}    — anonymous aggregated rating signal
//   venues/{placeId}/aggregates/*     — rolling averages (server-only writes)

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- helpers --------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Hard-cap field mutations on anonymous rating writes so clients can't
    // spam arbitrary data into the aggregate collection.
    function isAnonymousRating() {
      return request.resource.data.keys().hasOnly(
        ['rating', 'createdAt', 'placeId', 'category']
      )
      && request.resource.data.rating is number
      && request.resource.data.rating >= 0
      && request.resource.data.rating <= 5;
    }

    // ---- user profiles & subcollections ---------------------------------
    match /users/{uid} {
      allow read:   if isOwner(uid);
      allow create: if isOwner(uid)
                    && request.resource.data.keys().hasAll(['createdAt'])
                    && request.resource.data.createdAt == request.time;
      allow update: if isOwner(uid);
      allow delete: if false; // account deletion goes through a Cloud Function

      match /saved/{id} {
        allow read, write: if isOwner(uid);
      }

      match /alerts/{id} {
        allow read, write: if isOwner(uid);
      }

      match /dates/{dateId} {
        // Personal ratings & notes — owner only.
        allow read, write: if isOwner(uid);
      }
    }

    // ---- venue catalog (readable by everyone) ---------------------------
    match /venues/{placeId} {
      allow read: if true;
      allow write: if false; // venue docs are written by server only

      // Anonymous aggregated rating signal.
      // Any signed-in user can contribute one shaped doc.
      // They cannot read or modify other users' ratings.
      match /ratings/{ratingId} {
        allow create: if isSignedIn() && isAnonymousRating();
        allow read:   if false;
        allow update: if false;
        allow delete: if false;
      }

      // Aggregated counters are written only by a Cloud Function via Admin SDK.
      match /aggregates/{doc=**} {
        allow read:  if true;
        allow write: if false;
      }
    }

    // ---- default deny ---------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
