# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# AI (itinerary copy generation)
GEMINI_API_KEY=your-gemini-api-key-here

# Google services (sheet sync + place lookups)
GOOGLE_SHEETS_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SHEETS_PRIVATE_KEY=your-service-account-private-key-here
GOOGLE_SHEET_ID=your-venue-sheet-id-here
GOOGLE_PLACES_API_KEY=your-google-places-api-key-here

# Weather
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key-here

# Maps (walk route static images — itinerary still renders without it)
MAPBOX_TOKEN=your-mapbox-token-here
